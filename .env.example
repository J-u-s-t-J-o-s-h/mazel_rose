# Public site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=mazel.rose
NEXT_PUBLIC_WEDDING_DATE=2027-10-18T16:00:00-04:00
NEXT_PUBLIC_RSVP_DEADLINE=2027-09-01
NEXT_PUBLIC_NOINDEX=true

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-01
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_REVALIDATE_SECRET=

# RSVP provider: local | airtable | supabase
# Guest responses are NOT stored in Sanity.
RSVP_PROVIDER=local
RSVP_SECRET=

# Airtable (when RSVP_PROVIDER=airtable)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=RSVPs

# Supabase (when RSVP_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional site-wide password gate (proxy.ts)
ENABLE_SITE_PASSWORD=false
SITE_PASSWORD=
